{
  "input_schema": {
    "$id": "urn:eggsec:tool:detect_technology:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Technology detection request for the detect_technology tool",
    "properties": {
      "target": {
        "description": "Target URL",
        "type": "string"
      },
      "timeout_ms": {
        "description": "Timeout in milliseconds",
        "type": "integer"
      }
    },
    "required": [
      "target"
    ],
    "title": "Technology detection request",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "operation_id": "detect_technology",
  "output_schema": {
    "$id": "urn:eggsec:tool:detect_technology:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Technology detection result for the detect_technology tool",
    "properties": {
      "technologies": {
        "items": {
          "properties": {
            "category": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "type": "array"
      }
    },
    "title": "Technology detection result",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "tool_id": "detect_technology",
  "version": "0.1.0"
}
