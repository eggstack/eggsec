{
  "input_schema": {
    "$id": "urn:eggsec:tool:scan_git_secrets:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Git secrets scan request for the scan_git_secrets tool",
    "properties": {
      "depth": {
        "description": "Scan depth (commit history)",
        "type": "integer"
      },
      "path": {
        "description": "Repository path",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "Git secrets scan request",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "operation_id": "scan_git_secrets",
  "output_schema": {
    "$id": "urn:eggsec:tool:scan_git_secrets:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Git secrets scan result for the scan_git_secrets tool",
    "properties": {
      "findings": {
        "items": {
          "$ref": "#/$defs/Finding"
        },
        "type": "array"
      },
      "summary": {
        "type": "object"
      }
    },
    "title": "Git secrets scan result",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "tool_id": "scan_git_secrets",
  "version": "0.1.0"
}
