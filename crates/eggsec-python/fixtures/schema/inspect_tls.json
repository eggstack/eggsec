{
  "input_schema": {
    "$id": "urn:eggsec:tool:inspect_tls:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "TLS inspection request for the inspect_tls tool",
    "properties": {
      "target": {
        "description": "Target host:port",
        "type": "string"
      },
      "timeout_ms": {
        "description": "Timeout in milliseconds",
        "type": "integer"
      }
    },
    "required": [
      "target"
    ],
    "title": "TLS inspection request",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "operation_id": "inspect_tls",
  "output_schema": {
    "$id": "urn:eggsec:tool:inspect_tls:input",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "TLS inspection result for the inspect_tls tool",
    "properties": {
      "certificate": {
        "type": "object"
      },
      "issues": {
        "items": {
          "type": "string"
        },
        "type": "array"
      }
    },
    "title": "TLS inspection result",
    "type": "object",
    "x-eggsec-maturity": "stable",
    "x-eggsec-risk": "safe_active"
  },
  "tool_id": "inspect_tls",
  "version": "0.1.0"
}
