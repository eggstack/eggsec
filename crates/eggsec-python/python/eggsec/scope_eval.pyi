class ScopeSourcePy:
    @staticmethod
    def default_empty() -> ScopeSourcePy: ...
    @staticmethod
    def config_file(path: str) -> ScopeSourcePy: ...
    @staticmethod
    def cli_scope_file(path: str) -> ScopeSourcePy: ...
    @staticmethod
    def generated_preset(name: str) -> ScopeSourcePy: ...
    @property
    def name(self) -> str: ...

class ScopeRulePy:
    @property
    def pattern(self) -> str | None: ...
    @property
    def cidr(self) -> str | None: ...
    @property
    def description(self) -> str | None: ...

class ScopeExplanationPy:
    @property
    def allowed(self) -> bool: ...
    @property
    def reason(self) -> str: ...
    @property
    def matched_rules(self) -> list[str]: ...
    @property
    def excluded(self) -> bool: ...
    @property
    def exclusion_reason(self) -> str | None: ...

class ScopeValidationPy:
    @property
    def valid(self) -> bool: ...
    @property
    def errors(self) -> list[str]: ...
    @property
    def warnings(self) -> list[str]: ...
    @property
    def target_count(self) -> int: ...
    @property
    def exclusion_count(self) -> int: ...

class LoadedScopePy:
    @staticmethod
    def default_empty() -> LoadedScopePy: ...
    @property
    def source(self) -> ScopeSourcePy: ...
    @property
    def path(self) -> str | None: ...
    @property
    def is_explicit(self) -> bool: ...
    @property
    def allowed_targets(self) -> list[ScopeRulePy]: ...
    @property
    def excluded_targets(self) -> list[ScopeRulePy]: ...
    @property
    def allowed_ports(self) -> list[int]: ...
    @property
    def excluded_ports(self) -> list[int]: ...
    @property
    def max_requests_per_second(self) -> int: ...
    @property
    def require_explicit_scope(self) -> bool: ...
    def is_target_allowed(self, target: str) -> bool: ...
    def is_port_allowed(self, port: int) -> bool: ...
    def is_excluded(self, target: str) -> bool: ...
    def explain(self, target: str) -> ScopeExplanationPy: ...

def validate_scope(scope: LoadedScopePy) -> ScopeValidationPy: ...
