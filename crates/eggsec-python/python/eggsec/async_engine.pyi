from typing import Any, Dict, Literal, Optional
from .scope import Scope
from .runtime import PyFuture
from .planning import ScanPlan
from .requests import (
    OperationRequest,
    PortScanRequest,
    EndpointScanRequest,
    FingerprintRequest,
    ReconDnsRequest,
    TlsInspectRequest,
    TechDetectRequest,
    WafDetectRequest,
    LoadTestRequest,
    WafValidateRequest,
    FuzzRequest,
    GitSecretsScanRequest,
    SbomRequest,
    ConsolidatedReconRequest,
    GraphqlTestRequest,
    OauthTestRequest,
    AuthTestRequest,
    DbProbeRequest,
    NseRunRequest,
    DockerImageScanRequest,
    KubernetesScanRequest,
    ApkAnalysisRequest,
    IpaAnalysisRequest,
)
from .cancellation import CancellationToken
from .tool_core import ToolRequest

OperationId = Literal[
    "scan_ports", "scan_endpoints", "fingerprint_services", "recon_dns",
    "inspect_tls", "detect_technology", "detect_waf", "validate_waf",
    "fuzz_http", "load_test", "scan_git_secrets", "generate_sbom",
    "run_consolidated_recon", "graphql_test", "oauth_test", "auth_test",
    "db_probe", "nse_run", "scan_docker_image", "scan_kubernetes",
    "analyze_apk", "analyze_ipa",
]

class AsyncEngine:
    def __init__(
        self,
        scope: Scope,
        *,
        mode: str = "manual",
        concurrency: int = 100,
        timeout_ms: int = 5000,
    ) -> None: ...
    @staticmethod
    def local(
        scope: Scope,
        *,
        mode: str = "manual",
        concurrency: int = 100,
        timeout_ms: int = 5000,
    ) -> AsyncEngine: ...
    @staticmethod
    def daemon(
        socket_path: str,
        *,
        session_id: Optional[str] = None,
        mode: str = "manual",
        concurrency: int = 100,
        timeout_ms: int = 5000,
    ) -> AsyncEngine: ...
    def run(
        self,
        request: OperationRequest,
        *,
        cancel_token: Optional[CancellationToken] = None,
    ) -> PyFuture: ...
    def list_operations(self) -> list[str]: ...
    def has_operation(self, operation_id: str) -> bool: ...
    def audit_events(self) -> list[Any]: ...
    def run_port_scan(self, request: PortScanRequest) -> PyFuture: ...
    def run_endpoint_scan(self, request: EndpointScanRequest) -> PyFuture: ...
    def run_fingerprint(self, request: FingerprintRequest) -> PyFuture: ...
    def run_recon_dns(self, request: ReconDnsRequest) -> PyFuture: ...
    def run_tls_inspect(self, request: TlsInspectRequest) -> PyFuture: ...
    def run_tech_detect(self, request: TechDetectRequest) -> PyFuture: ...
    def run_waf_detect(self, request: WafDetectRequest) -> PyFuture: ...
    def run_load_test(self, request: LoadTestRequest) -> PyFuture: ...
    def run_waf_validate(self, request: WafValidateRequest) -> PyFuture: ...
    def run_fuzz(self, request: FuzzRequest) -> PyFuture: ...
    def run_git_secrets(self, request: GitSecretsScanRequest) -> PyFuture: ...
    def run_sbom(self, request: SbomRequest) -> PyFuture: ...
    def run_consolidated_recon(self, request: ConsolidatedReconRequest) -> PyFuture: ...
    def run_graphql_test(self, request: GraphqlTestRequest) -> PyFuture: ...
    def run_oauth_test(self, request: OauthTestRequest) -> PyFuture: ...
    def run_auth_test(self, request: AuthTestRequest) -> PyFuture: ...
    def run_db_probe(self, request: DbProbeRequest) -> PyFuture: ...
    def run_nse(self, request: NseRunRequest) -> PyFuture: ...
    def run_docker_scan(self, request: DockerImageScanRequest) -> PyFuture: ...
    def run_kubernetes_scan(self, request: KubernetesScanRequest) -> PyFuture: ...
    def run_apk_analysis(self, request: ApkAnalysisRequest) -> PyFuture: ...
    def run_ipa_analysis(self, request: IpaAnalysisRequest) -> PyFuture: ...
    def plan(self, target: str) -> PyFuture: ...
    def async_invoke_tool(
        self,
        tool_id: str,
        target: str,
        payload: Optional[Dict[str, Any]] = None,
        timeout_ms: Optional[int] = None,
    ) -> PyFuture: ...
    def async_invoke_tool_request(self, request: ToolRequest) -> PyFuture: ...
    @property
    def scope(self) -> Scope: ...
    @property
    def mode(self) -> str: ...
    @property
    def concurrency(self) -> int: ...
    @property
    def timeout_ms(self) -> int: ...
    def close(self) -> None: ...
    async def __aenter__(self) -> AsyncEngine: ...
    async def __aexit__(self, *args: object) -> None: ...
    def __repr__(self) -> str: ...
