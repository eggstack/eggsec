class BrowserSession:
    def __init__(self, config: BrowserSessionConfig) -> None: ...
    @property
    def session_id(self) -> str: ...
    @property
    def config(self) -> BrowserSessionConfig: ...
    @property
    def state(self) -> BrowserSessionState: ...
    @property
    def stats(self) -> BrowserSessionStats: ...
    def start(self) -> None: ...
    def stop(self) -> None: ...
    def navigate(self, url: str) -> BrowserNavigationEvent: ...
    def wait_for_selector(self, selector: str, timeout_ms: Optional[int] = None) -> bool: ...
    def get_dom_snapshot(self) -> BrowserDomSnapshot: ...
    def get_console_events(self) -> List[BrowserConsoleEvent]: ...
    def get_network_events(self) -> List[BrowserNetworkEvent]: ...
    def get_cookies(self) -> BrowserStorageInfo: ...
    def take_screenshot(self) -> ArtifactReference: ...
    def execute_script(self, script: str, timeout_ms: Optional[int] = None) -> str: ...
    def __enter__(self) -> BrowserSession: ...
    def __exit__(self, *args: Any) -> bool: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class AsyncBrowserSession:
    def __init__(self, config: BrowserSessionConfig) -> None: ...
    @property
    def session_id(self) -> str: ...
    @property
    def config(self) -> BrowserSessionConfig: ...
    @property
    def state(self) -> BrowserSessionState: ...
    @property
    def stats(self) -> BrowserSessionStats: ...
    def async_start(self) -> Any: ...
    def async_stop(self) -> Any: ...
    def async_navigate(self, url: str) -> Any: ...
    def async_wait_for_selector(self, selector: str, timeout_ms: Optional[int] = None) -> Any: ...
    def async_get_dom_snapshot(self) -> Any: ...
    def async_get_console_events(self) -> Any: ...
    def async_get_network_events(self) -> Any: ...
    def async_get_cookies(self) -> Any: ...
    def async_take_screenshot(self) -> Any: ...
    def async_execute_script(self, script: str, timeout_ms: Optional[int] = None) -> Any: ...
    def __aenter__(self) -> AsyncBrowserSession: ...
    def __aexit__(self, *args: Any) -> bool: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
