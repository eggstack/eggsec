        self,
        *,
        engine: str = "",
        version: Optional[str] = None,
        supports_javascript: bool = False,
        supports_dom: bool = False,
        supports_network_intercept: bool = False,
        supports_console_capture: bool = False,
        supports_screenshot: bool = False,
        supports_pdf_export: bool = False,
        supports_cookie_access: bool = False,
        supports_storage_access: bool = False,
        supports_route_discovery: bool = False,
        supports_proxy: bool = False,
    ) -> None: ...
    @property
    def engine(self) -> str: ...
    @property
    def version(self) -> Optional[str]: ...
    @property
    def supports_javascript(self) -> bool: ...
    @property
    def supports_dom(self) -> bool: ...
    @property
    def supports_network_intercept(self) -> bool: ...
    @property
    def supports_console_capture(self) -> bool: ...
    @property
    def supports_screenshot(self) -> bool: ...
    @property
    def supports_pdf_export(self) -> bool: ...
    @property
    def supports_cookie_access(self) -> bool: ...
    @property
    def supports_storage_access(self) -> bool: ...
    @property
    def supports_route_discovery(self) -> bool: ...
    @property
    def supports_proxy(self) -> bool: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...

class BrowserSessionState:
    Created: "BrowserSessionState"
    Discovering: "BrowserSessionState"
    Launching: "BrowserSessionState"
    Ready: "BrowserSessionState"
    Navigating: "BrowserSessionState"
    Loading: "BrowserSessionState"
    Inspecting: "BrowserSessionState"
    Stopping: "BrowserSessionState"
    Cleaning: "BrowserSessionState"
    Stopped: "BrowserSessionState"
    Failed: "BrowserSessionState"
    Cancelled: "BrowserSessionState"
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

