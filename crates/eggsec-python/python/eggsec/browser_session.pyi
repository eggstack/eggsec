from typing import Any, Dict, List, Optional, Tuple

class BrowserCapabilities:
    def __init__(
        self,
        *,
        headless: bool = True,
        screenshot: bool = True,
        pdf_export: bool = True,
        network_intercept: bool = False,
        console_capture: bool = True,
        cookie_access: bool = True,
        local_storage_access: bool = True,
        dom_snapshot: bool = True,
        form_interaction: bool = True,
        javascript_execution: bool = True,
    ) -> None: ...
    @property
    def headless(self) -> bool: ...
    @property
    def screenshot(self) -> bool: ...
    @property
    def pdf_export(self) -> bool: ...
    @property
    def network_intercept(self) -> bool: ...
    @property
    def console_capture(self) -> bool: ...
    @property
    def cookie_access(self) -> bool: ...
    @property
    def local_storage_access(self) -> bool: ...
    @property
    def dom_snapshot(self) -> bool: ...
    @property
    def form_interaction(self) -> bool: ...
    @property
    def javascript_execution(self) -> bool: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class BrowserSessionState:
    Idle: "BrowserSessionState"
    Navigating: "BrowserSessionState"
    Loading: "BrowserSessionState"
    Ready: "BrowserSessionState"
    Evaluating: "BrowserSessionState"
    Closed: "BrowserSessionState"
    Error: "BrowserSessionState"
    @property
    def value(self) -> str: ...
    def from_str(s: str) -> BrowserSessionState: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class BrowserSessionConfig:
