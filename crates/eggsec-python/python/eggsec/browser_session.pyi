class BrowserSession:
    def __init__(self, config: BrowserSessionConfig) -> None: ...
    @property
    def config(self) -> BrowserSessionConfig: ...
    @property
    def state(self) -> BrowserSessionState: ...
    @property
    def session_id(self) -> str: ...
    @property
    def stats(self) -> BrowserSessionStats: ...
    def start(self) -> BrowserCapabilities: ...
    def navigate(self, url: str) -> BrowserNavigationEvent: ...
    def current_url(self) -> str: ...
    def screenshot(self, *, full_page: bool = False) -> bytes: ...
    def pdf(self) -> bytes: ...
    def evaluate(self, script: str) -> Any: ...
    def snapshot(self) -> BrowserDomSnapshot: ...
    def forms(self) -> List[BrowserFormInfo]: ...
    def links(self) -> List[BrowserLinkInfo]: ...
    def storage(self) -> BrowserStorageInfo: ...
    def set_cookie(self, cookie: BrowserCookieInfo) -> None: ...
    def clear_cookies(self) -> None: ...
    def console_events(self) -> List[BrowserConsoleEvent]: ...
    def network_events(self) -> List[BrowserNetworkEvent]: ...
    def close(self) -> None: ...
    def __enter__(self) -> BrowserSession: ...
    def __exit__(self, *args: Any) -> bool: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

class AsyncBrowserSession:
    def __init__(self, config: BrowserSessionConfig) -> None: ...
    @property
    def config(self) -> BrowserSessionConfig: ...
    @property
    def state(self) -> BrowserSessionState: ...
    @property
    def session_id(self) -> str: ...
    def async_start(self) -> Any: ...
    def async_navigate(self, url: str) -> Any: ...
    def async_current_url(self) -> Any: ...
    def async_screenshot(self, *, full_page: bool = False) -> Any: ...
    def async_pdf(self) -> Any: ...
    def async_evaluate(self, script: str) -> Any: ...
    def async_snapshot(self) -> Any: ...
    def async_forms(self) -> Any: ...
    def async_links(self) -> Any: ...
    def async_storage(self) -> Any: ...
    def async_set_cookie(self, cookie: BrowserCookieInfo) -> Any: ...
    def async_clear_cookies(self) -> Any: ...
    def async_console_events(self) -> Any: ...
    def async_network_events(self) -> Any: ...
    def async_close(self) -> Any: ...
    def __aenter__(self) -> AsyncBrowserSession: ...
    def __aexit__(self, *args: Any) -> None: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
