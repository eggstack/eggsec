    def supports_launch(self) -> bool: ...
    @property
    def supports_frida(self) -> bool: ...
    @property
    def supports_log_capture(self) -> bool: ...
    @property
    def supports_screenshot(self) -> bool: ...
    @property
    def supports_network_capture(self) -> bool: ...
    @property
    def supports_filesystem_extract(self) -> bool: ...
