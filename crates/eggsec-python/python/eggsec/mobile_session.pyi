from typing import Any, Dict, List, Optional

from .artifact import ArtifactReference

class MobileDeviceDescriptor:
    def __init__(
        self,
        serial: str,
        *,
        model: Optional[str] = None,
        platform: str = "android",
        android_version: Optional[str] = None,
        sdk_version: Optional[int] = None,
        abi: Optional[str] = None,
        is_emulator: bool = False,
        is_rooted: bool = False,
        transport: str = "usb",
        authorization_status: str = "unknown",
        supported_operations: Optional[List[str]] = None,
    ) -> None: ...
    @property
    def serial(self) -> str: ...
    @property
    def model(self) -> Optional[str]: ...
    @property
    def platform(self) -> str: ...
    @property
    def android_version(self) -> Optional[str]: ...
    @property
    def sdk_version(self) -> Optional[int]: ...
    @property
    def abi(self) -> Optional[str]: ...
    @property
    def is_emulator(self) -> bool: ...
    @property
    def is_rooted(self) -> bool: ...
    @property
    def transport(self) -> str: ...
    @property
    def authorization_status(self) -> str: ...
    @property
    def supported_operations(self) -> List[str]: ...
    def to_dict(self) -> Dict[str, Any]: ...
    def to_json(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...

